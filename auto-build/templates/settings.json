{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "GNAP_ROLE": "architect"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/architect-no-direct-write.sh",
            "timeout": 8
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-lint.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/notify-telegram.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(jq *)",
      "Bash(date *)",
      "Bash(printf *)",
      "Bash(echo *)",
      "Bash(mkdir -p *)",
      "Bash(touch .autonomy/*)",
      "Bash(rm -f .autonomy/*)",
      "Bash(python - *)",
      "Bash(python3 - *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git log *)",
      "Bash(git rev-parse *)",
      "Bash(git branch --show-current)",
      "Bash(git branch --list *)",
      "Bash(git merge --ff-only *)",
      "Bash(git worktree list *)",
      "Bash(.claude/bin/sonnet-worker.sh *)",
      "Bash(.claude/bin/codex-worker.sh *)",
      "Bash(.claude/bin/gemini-worker.sh *)",
      "Bash(.claude/bin/autonomy-supervisor.sh *)",
      "Bash(chmod 755 *)",
      "Bash(chmod +x *)"
    ],
    "deny": [
      "Agent",
      "Agent(*)",
      "Bash(claude -p *)",
      "Bash(codex exec *)",
      "Bash(gemini -p *)",
      "Bash(gemini --prompt *)",
      "Bash(git apply *)",
      "Bash(git am *)",
      "Bash(patch *)",
      "Bash(sed -i *)",
      "Bash(perl -pi *)",
      "Bash(ruby -pi *)",
      "Bash(python -c *)",
      "Bash(python3 -c *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rsync *)",
      "Bash(install *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git cherry-pick *)",
      "Bash(git reset --hard *)",
      "Bash(git push --force *)",
      "Bash(git push * --force *)",
      "Bash(git clean -f *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": false,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "excludedCommands": [
      ".claude/bin/sonnet-worker.sh *",
      ".claude/bin/codex-worker.sh *",
      ".claude/bin/gemini-worker.sh *",
      ".claude/bin/autonomy-supervisor.sh *"
    ]
  }
}
